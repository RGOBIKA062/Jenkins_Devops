# ==========================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# ==========================================
# IMPORTANT: Copy this file to .env and fill in your values
# NEVER commit .env file to Git
# ==========================================

# ==========================================
# SERVER CONFIGURATION
# ==========================================
NODE_ENV=development
PORT=5000
API_VERSION=v1
API_PREFIX=/api

# ==========================================
# GROQ API CONFIGURATION
# ==========================================
# Get your API key from: https://console.groq.com
# VERIFIED AVAILABLE MODELS (Tested and working):
# - llama-3.1-8b-instant (BEST for code execution, fast and reliable)
# - llama-3.3-70b-versatile (Fallback, very good performance)
# - llama-3.1-8b-instant (Lightweight fallback, fastest)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
GROQ_FALLBACK_MODEL=llama-3.3-70b-versatile
GROQ_TERTIARY_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT=30000
GROQ_MAX_RETRIES=3

# ==========================================
# FRONTEND CONFIGURATION
# ==========================================
FRONTEND_URL=http://localhost:8080
FRONTEND_URL_ALT=http://localhost:5173

# ==========================================
# SECURITY CONFIGURATION
# ==========================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
CORS_ORIGIN=http://localhost:8080,http://localhost:5173
HELMET_ENABLED=true
CSRF_PROTECTION=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
SESSION_TIMEOUT=3600000

# ==========================================
# CODE EXECUTION CONFIGURATION
# ==========================================
CODE_EXECUTION_TIMEOUT=5000
MAX_CODE_LENGTH=10000
MAX_OUTPUT_SIZE=50000
MAX_EXECUTION_MEMORY=256
ALLOWED_LANGUAGES=javascript,python,java,cpp

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
MONGODB_URI=mongodb://localhost:27017/allcollegeevents

# ==========================================
# LOGGING CONFIGURATION
# ==========================================
LOG_LEVEL=info
LOG_DIR=./logs
LOG_FILE_MAX_SIZE=5m
LOG_FILE_MAX_FILES=10

# ==========================================
# FEATURE FLAGS
# ==========================================
ENABLE_COMPILER=true
ENABLE_TAB_LOCKING=true
ENABLE_AUTO_TESTING=true
ENABLE_GROQ_EXECUTION=true
ANALYTICS_ENABLED=false

# ==========================================
# RATE LIMITING
# ==========================================
MAX_SUBMISSIONS_PER_HOUR=50
MAX_TEST_CASES=100

# ==========================================
# EMAIL CONFIGURATION (Optional)
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ==========================================
# MONITORING & DEBUGGING
# ==========================================
DEBUG_MODE=false
VERBOSE_LOGGING=false
